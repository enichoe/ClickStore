{
  "version": 2,
  "buildCommand": "node scripts/generate-env.js",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/views/(.*)",
      "destination": "/views/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/js/$1"
    },
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}