{
  "version": 2,
  "buildCommand": "node scripts/generate-env.js",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/views/(.+)",
      "dest": "/views/$1"
    },
    {
      "src": "/js/(.+)",
      "dest": "/js/$1"
    },
    {
      "src": "/css/(.+)",
      "dest": "/css/$1"
    },
    {
      "src": "^/[^.]+$",
      "dest": "/index.html"
    }
  ]
}